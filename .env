# Modalità SSO: 'production' o 'dev'
# In modalità 'dev' non serve il portale reale: il login è simulato automaticamente.
SSO_MODE=dev

# Email usata in modalità dev (ignorata in production)
DEV_USER_EMAIL=vivo.ciro.studente@itispaleocapa.it

# Secret condiviso con il portale SSO (DEVE essere identico)
JWT_SECRET=cambia-questa-stringa-con-un-segreto-sicuro

# Identificativo univoco di questa applicazione nei JWT
# Deve corrispondere all'audience configurata sul portale per questa app.
APP_AUDIENCE=blueprint-app

# URL del portale SSO (usato per redirect login/logout)
PORTAL_URL=http://localhost:5000

# Secret Flask per firmare i cookie di sessione
SERVER_SECRET_KEY=altra-stringa-segreta-e-lunga

# Rate limiting
MAX_SESSIONS_PER_USER=3       # Max sessioni simultanee per lo stesso utente
MAX_SESSIONS_GLOBAL=100       # Max sessioni attive totali nell'applicazione

# Porta dell'applicazione
PORT=3020

# Debug (mai True in production)
DEBUG=False