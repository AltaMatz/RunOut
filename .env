# ============================================================
# AMBIENTE: 'development' o 'production'
# ============================================================
APP_ENV=development

# ============================================================
# MODALITÀ SSO: 'dev' o 'production'
# - 'dev': simula il login senza portale reale (SOLO per testing locale)
# - 'production': richiede JWT valido dal portale SSO reale
# ============================================================
SSO_MODE=dev

# Email usata SOLO in modalità dev (ignorata in production)
DEV_USER_EMAIL=cognome.nome.studente@itispaleocapa.it

# Email docente per testing in modalità dev
DEV_DOCENTE_EMAIL=nome.cognome@itispaleocapa.it

# ============================================================
# JWT - CREDENZIALI CONDIVISE CON IL PORTALE SSO
# IMPORTANTE: questi valori DEVONO essere identici nel portale!
# ============================================================

# Secret per firmare/verificare i JWT (CAMBIATE in production!)
# Generare con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SSO_JWT_SECRET=cambia-questa-stringa-con-un-segreto-sicuro-IMPORTANTE

# Identificativo dell'emittente del JWT (portale SSO)
SSO_JWT_ISSUER=sso-portal

# Identificativo audience - deve corrispondere all'audience nel JWT dal portale
# (identifica QUESTA applicazione)
SSO_JWT_AUDIENCE=mia-app

# URL del portale SSO (usato per redirect login/logout e errori)
SSO_PORTAL_URL=http://localhost:5000

# ============================================================
# FLASK - Configurazione sicurezza
# ============================================================

# Secret key per firmare i cookie di sessione Flask
# Generare con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CAMBIATE in production!
FLASK_SECRET_KEY=altra-stringa-segreta-e-lunga-CAMBIATE-IN-PRODUCTION

# Durata sessione in secondi (28800 = 8 ore)
SESSION_LIFETIME_SECONDS=28800

# ============================================================
# RATE LIMITING
# ============================================================

# Massimo numero di sessioni simultanee per lo stesso utente
MAX_SESSIONS_PER_USER=3

# Massimo numero di sessioni attive totali nell'applicazione
MAX_SESSIONS_GLOBAL=100

# ============================================================
# APPLICAZIONE
# ============================================================

# Porta su cui gira l'applicazione
PORT=3020

# Debug mode (MAI True in production!)
DEBUG=False
