# ============================================================
# FLASK CORE
# ============================================================
FLASK_SECRET_KEY=your-super-secret-key-change-this-in-production

# ============================================================
# SSO CONFIGURATION
# ============================================================
SSO_MODE=production
SSO_JWT_SECRET=your-jwt-secret-from-sso-portal
SSO_JWT_ISSUER=sso-portal
SSO_JWT_AUDIENCE=mia-app
SSO_PORTAL_URL=http://sso-portal:5000

# ============================================================
# DEV MODE (optional, used only if SSO_MODE=dev)
# ============================================================
DEV_USER_EMAIL=vivo.ciro.studente@itispaleocapa.it
DEV_DOCENTE_EMAIL=luca.todaro@itispaleocapa.it

# ============================================================
# API CONFIGURATION
# ============================================================
API_TOKEN=your-api-token-here

# ============================================================
# SESSION
# ============================================================
SESSION_LIFETIME_SECONDS=28800
